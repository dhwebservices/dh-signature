<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.1" xsi:type="MailApp">
  <Id>9c5603c8-2fd8-4c80-9f87-25f7efb0db35</Id>
  <Version>0.1.0.0</Version>
  <ProviderName>DH Website Services</ProviderName>
  <DefaultLocale>en-GB</DefaultLocale>
  <DisplayName DefaultValue="DH Signature" />
  <Description DefaultValue="Tenant-wide Outlook signature platform for DH Website Services." />
  <IconUrl DefaultValue="https://dhwebsiteservices.co.uk/favicon.ico" />
  <HighResolutionIconUrl DefaultValue="https://dhwebsiteservices.co.uk/favicon.ico" />
  <SupportUrl DefaultValue="https://dhwebsiteservices.co.uk" />
  <AppDomains>
    <AppDomain>https://dhwebsiteservices.co.uk</AppDomain>
    <AppDomain>https://sig.dhwebsiteservices.co.uk</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>
  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.10" />
    </Sets>
  </Requirements>
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://sig.dhwebsiteservices.co.uk/taskpane/index.html" />
        <RequestedHeight>320</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>
  <Permissions>ReadWriteItem</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit" />
  </Rule>
  <DisableEntityHighlighting>false</DisableEntityHighlighting>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_1">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.10">
        <bt:Set Name="Mailbox" />
      </bt:Sets>
    </Requirements>
    <Hosts>
      <Host xsi:type="MailHost">
        <Runtimes>
          <Runtime resid="Autorun.Url">
            <Override type="javascript" resid="Autorun.Script" />
          </Runtime>
        </Runtimes>
        <DesktopFormFactor>
          <FunctionFile resid="Commands.Url" />
          <ExtensionPoint xsi:type="LaunchEvent">
            <LaunchEvents>
              <LaunchEvent Type="OnNewMessageCompose" FunctionName="onNewMessageComposeHandler" SendMode="SoftBlock" />
            </LaunchEvents>
            <SourceLocation resid="Autorun.Url" />
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://sig.dhwebsiteservices.co.uk/commands/commands.html" />
        <bt:Url id="Autorun.Url" DefaultValue="https://sig.dhwebsiteservices.co.uk/commands/commands.html" />
        <bt:Url id="Autorun.Script" DefaultValue="https://sig.dhwebsiteservices.co.uk/commands/commands.js" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="DH Signature" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="PaneDescription" DefaultValue="DH-owned Outlook signature platform." />
      </bt:LongStrings>
    </Resources>
    <WebApplicationInfo>
      <Id>87f9f2d1-5841-406a-b365-d2215550347b</Id>
      <Resource>api://sig.dhwebsiteservices.co.uk/87f9f2d1-5841-406a-b365-d2215550347b</Resource>
      <Scopes>
        <Scope>access_as_user</Scope>
      </Scopes>
    </WebApplicationInfo>
  </VersionOverrides>
</OfficeApp>
