<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides"
  xsi:type="MailApp">
  <Id>9c5603c8-2fd8-4c80-9f87-25f7efb0db35</Id>
  <Version>0.1.10.0</Version>
  <ProviderName>DH Website Services</ProviderName>
  <DefaultLocale>en-GB</DefaultLocale>
  <DisplayName DefaultValue="DH Signature" />
  <Description DefaultValue="Tenant-wide Outlook signature platform for DH Website Services." />
  <IconUrl DefaultValue="https://sig.dhwebsiteservices.co.uk/icons/dh-logo-icon.png" />
  <HighResolutionIconUrl DefaultValue="https://sig.dhwebsiteservices.co.uk/icons/dh-logo.png" />
  <SupportUrl DefaultValue="https://dhwebsiteservices.co.uk" />
  <AppDomains>
    <AppDomain>https://dhwebsiteservices.co.uk</AppDomain>
    <AppDomain>https://sig.dhwebsiteservices.co.uk</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>
  <Requirements>
    <Sets DefaultMinVersion="1.1">
      <Set Name="Mailbox" />
    </Sets>
  </Requirements>
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://sig.dhwebsiteservices.co.uk/taskpane/index.html" />
        <RequestedHeight>320</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>
  <Permissions>ReadWriteMailbox</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read" />
  </Rule>
  <DisableEntityHighlighting>true</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1" xsi:type="VersionOverridesV1_1">
      <Description resid="residAppDesc" />
      <Requirements>
        <bt:Sets DefaultMinVersion="1.5">
          <bt:Set Name="Mailbox" />
        </bt:Sets>
      </Requirements>
      <Hosts>
        <Host xsi:type="MailHost">
          <Runtimes>
            <Runtime resid="WebViewRuntime.Url" />
          </Runtimes>
          <DesktopFormFactor>
            <FunctionFile resid="Commands.Url" />
            <ExtensionPoint xsi:type="MessageComposeCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="dhSignatureGroupCompose">
                  <Label resid="GroupLabel" />
                  <Control xsi:type="Button" id="dhSignatureTaskpaneButton">
                    <Label resid="PaneTitle" />
                    <Supertip>
                      <Title resid="PaneTitle" />
                      <Description resid="PaneDescription" />
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon16" />
                      <bt:Image size="32" resid="Icon32" />
                      <bt:Image size="80" resid="Icon80" />
                    </Icon>
                    <Action xsi:type="ShowTaskpane">
                      <SourceLocation resid="Taskpane.Url" />
                    </Action>
                  </Control>
                </Group>
              </OfficeTab>
            </ExtensionPoint>
            <ExtensionPoint xsi:type="LaunchEvent">
              <LaunchEvents>
                <LaunchEvent Type="OnNewMessageCompose" FunctionName="onNewMessageComposeHandler" />
              </LaunchEvents>
              <SourceLocation resid="WebViewRuntime.Url" />
            </ExtensionPoint>
          </DesktopFormFactor>
          <MobileFormFactor>
            <FunctionFile resid="Commands.Url" />
            <ExtensionPoint xsi:type="MobileMessageReadCommandSurface">
              <Group id="dhSignatureMobileReadGroup">
                <Label resid="GroupLabel" />
                <Control xsi:type="MobileButton" id="dhSignatureMobileTaskpaneButton">
                  <Label resid="PaneTitle" />
                  <Icon xsi:type="bt:MobileIconList">
                    <bt:Image size="25" scale="1" resid="Icon25" />
                    <bt:Image size="25" scale="2" resid="Icon25" />
                    <bt:Image size="25" scale="3" resid="Icon25" />
                    <bt:Image size="32" scale="1" resid="Icon32" />
                    <bt:Image size="32" scale="2" resid="Icon32" />
                    <bt:Image size="32" scale="3" resid="Icon32" />
                    <bt:Image size="48" scale="1" resid="Icon48" />
                    <bt:Image size="48" scale="2" resid="Icon48" />
                    <bt:Image size="48" scale="3" resid="Icon48" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="Taskpane.Url" />
                  </Action>
                </Control>
              </Group>
            </ExtensionPoint>
            <ExtensionPoint xsi:type="LaunchEvent">
              <LaunchEvents>
                <LaunchEvent Type="OnNewMessageCompose" FunctionName="onNewMessageComposeHandler" />
              </LaunchEvents>
              <SourceLocation resid="WebViewRuntime.Url" />
            </ExtensionPoint>
          </MobileFormFactor>
        </Host>
      </Hosts>
      <Resources>
        <bt:Images>
          <bt:Image id="Icon16" DefaultValue="https://sig.dhwebsiteservices.co.uk/icons/dh-logo-icon.png" />
          <bt:Image id="Icon25" DefaultValue="https://sig.dhwebsiteservices.co.uk/icons/dh-logo-icon.png" />
          <bt:Image id="Icon32" DefaultValue="https://sig.dhwebsiteservices.co.uk/icons/dh-logo-icon.png" />
          <bt:Image id="Icon48" DefaultValue="https://sig.dhwebsiteservices.co.uk/icons/dh-logo-icon.png" />
          <bt:Image id="Icon80" DefaultValue="https://sig.dhwebsiteservices.co.uk/icons/dh-logo.png" />
        </bt:Images>
        <bt:Urls>
          <bt:Url id="Commands.Url" DefaultValue="https://sig.dhwebsiteservices.co.uk/commands/commands.html" />
          <bt:Url id="Taskpane.Url" DefaultValue="https://sig.dhwebsiteservices.co.uk/taskpane/index.html" />
          <bt:Url id="WebViewRuntime.Url" DefaultValue="https://sig.dhwebsiteservices.co.uk/commands/commands.html" />
        </bt:Urls>
        <bt:ShortStrings>
          <bt:String id="GroupLabel" DefaultValue="DH Signature" />
          <bt:String id="PaneTitle" DefaultValue="Open DH Signature" />
        </bt:ShortStrings>
        <bt:LongStrings>
          <bt:String id="residAppDesc" DefaultValue="Tenant-wide Outlook signature platform for DH Website Services." />
          <bt:String id="PaneDescription" DefaultValue="Preview and manage the live DH email signature for the current sender." />
        </bt:LongStrings>
      </Resources>
    </VersionOverrides>
  </VersionOverrides>
</OfficeApp>
