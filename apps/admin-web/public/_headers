/*
  Referrer-Policy: strict-origin-when-cross-origin
  X-Content-Type-Options: nosniff

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/commands/*
  Content-Security-Policy: frame-ancestors https://outlook.office.com https://outlook.office365.com https://*.office.com https://*.officeapps.live.com https://*.microsoft.com;
  X-Content-Type-Options: nosniff

/taskpane/*
  Content-Security-Policy: frame-ancestors https://outlook.office.com https://outlook.office365.com https://*.office.com https://*.officeapps.live.com https://*.microsoft.com;
  X-Content-Type-Options: nosniff
